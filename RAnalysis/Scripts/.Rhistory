Tank_Replicate == 'F' ~ 'B', #convert F to B
Tank_Replicate == 'G' ~ 'C', #convert G to C
Tank_Replicate == 'H' ~ 'D', #convert H to D
.default = (as.character(Tank_Replicate)) # for cases A-D, keep em my mans
