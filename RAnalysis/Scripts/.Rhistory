leveneTest(F3_TwoWayANOVA_dhinge) # 0.8975
summary(aov(F3_TwoWayANOVA_dhinge))
F3_TwoWayANOVA_day7 <- lm(mean_RR~pCO2_parents*pCO2_offspring, data=F3_DF_day7)
