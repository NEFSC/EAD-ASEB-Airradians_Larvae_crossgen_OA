df_MS_1
head(df_MS_1)
tail(df_MS_1)
df_MS_1_Low <- df_MS_1 %>% filter(Larvae_pCO2 == "Low pCO2")
aovMOD_MS_1_Low <- lm(Percent.deformed ~ Generation, data=df_MS_1_Low)
shapiro.test(resid(aovMOD_MS_1_Low)) # 0.9707 - norm
leveneTest(aovMOD_MS_1_Low) # 0.7656- pass
